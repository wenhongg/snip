{
  "name": "snip",
  "version": "1.1.2",
  "description": "Visual communication layer between humans and AI agents — capture, annotate, render diagrams, review",
  "author": "rixinw",
  "license": "MIT",
  "main": "src/main/main.js",
  "bin": {
    "snip": "src/cli/snip.js"
  },
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_ENABLE_LOGGING=1 electron .",
    "postinstall": "node -e \"if(process.platform==='darwin'){require('child_process').execSync('electron-builder install-app-deps',{stdio:'inherit'})}\"",
    "prebuild": "node -e \"if(process.platform==='darwin'){require('child_process').execSync('node-gyp rebuild',{stdio:'inherit'})}\"",
    "build": "node-gyp rebuild && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64 && npm run sign:adhoc",
    "build:linux": "electron-builder --linux --x64",
    "sign:adhoc": "for app in dist/mac-*/Snip.app; do if codesign -v \"$app\" 2>/dev/null; then echo \"Already signed: $app\"; else codesign --force --deep --sign - \"$app\" 2>/dev/null && echo \"Ad-hoc signed: $app\"; fi; done",
    "download-models": "node scripts/download-models.js",
    "download-node": "node scripts/download-node.js",
    "rebuild": "electron-rebuild",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "chokidar": "^4.0.0",
    "electron-updater": "^6.8.3",
    "fabric": "^7.0.0",
    "gifenc": "^1.0.3",
    "mermaid": "^11.13.0",
    "node-addon-api": "^8.5.0",
    "ollama": "^0.6.3",
    "upng-js": "^2.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@huggingface/transformers": "^3.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "ffmpeg-static": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "electron-liquid-glass": "^1.1.1"
  }
}
